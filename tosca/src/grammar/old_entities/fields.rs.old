// use super::super::data::*;

/// Refine a field.
pub fn refine_field<FieldT, GetParentFieldT>(
    field: &Option<FieldT>,
    get_parent_field: GetParentFieldT,
) -> Option<FieldT>
where
    FieldT: Clone,
    GetParentFieldT: Fn() -> Option<FieldT>,
{
    field.clone().or_else(get_parent_field)
}

/// Refine a field.
pub fn refine_field_from<FieldT>(field: &Option<FieldT>, parent_field: &Option<FieldT>) -> Option<FieldT>
where
    FieldT: Clone,
{
    refine_field(field, || parent_field.clone())
}

/// Refine a field.
pub fn refine_field_from_entity<FieldT, ParentEntityT, GetParentFieldT>(
    field: &Option<FieldT>,
    parent_entity: Option<ParentEntityT>,
    get_parent_field: GetParentFieldT,
) -> Option<FieldT>
where
    FieldT: Clone,
    GetParentFieldT: Fn(ParentEntityT) -> Option<FieldT>,
{
    field.clone().or_else(|| parent_entity.and_then(get_parent_field))
}

